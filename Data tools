# FERRAMENTA 2 — VALIDAÇÃO
# ─────────────────────────────────────────────

class DataValidationTool(BaseTool):
    name: str = "data_validation"
    description: str = (
        "Valida a qualidade dos dados ingeridos. "
        "Verifica completude, duplicatas, ranges, consistência temporal e outliers. "
        "Aplica correções automáticas e retorna score de qualidade."
    )
    args_schema: Type[BaseModel] = ValidateInput

    def _run(self, max_null_pct: float = 5.0, max_outlier_pct: float = 1.0) -> str:
        df = _SHARED_STATE.get("df_raw")
        if df is None:
            return json.dumps({"error": "Nenhum DataFrame encontrado. Execute data_ingestion primeiro."})

        logger.info(f"[DataValidationTool] Validando {len(df):,} registros")
        rules = []

        # Completude
        for col in ["trip_id", "fare_amount", "total_amount", "PULocationID"]:
            null_pct = df[col].isna().mean() * 100
            rules.append({
                "rule": f"completeness_{col}",
                "passed": null_pct <= max_null_pct,
                "detail": f"{round(null_pct,2)}% nulos"
            })

        # Duplicatas
        dup_pct = df.duplicated(subset=["trip_id"]).mean() * 100
        rules.append({"rule": "no_duplicates", "passed": dup_pct < 1.0, "detail": f"{round(dup_pct,3)}% duplicatas"})

        # Ranges
        rules.append({
            "rule": "range_fare_amount",
            "passed": bool(int(df["fare_amount"].between(0, 500).all())),
            "detail": f"min={float(df['fare_amount'].min()):.2f}, max={float(df['fare_amount'].max()):.2f}"
        })
        rules.append({
            "rule": "range_trip_distance",
            "passed": bool(int(df["trip_distance"].between(0, 200).all())),
            "detail": f"max={float(df['trip_distance'].max()):.2f}"
        })

        # Consistência temporal
        temporal_ok = bool(int((df["tpep_pickup_datetime"] < df["tpep_dropoff_datetime"]).all()))
        rules.append({"rule": "temporal_consistency", "passed": temporal_ok, "detail": "pickup < dropoff"})

        # Outliers IQR
        for col in ["fare_amount", "trip_distance"]:
            q1, q3 = df[col].quantile(0.25), df[col].quantile(0.75)
            iqr = q3 - q1
            outliers = ((df[col] < q1 - 3*iqr) | (df[col] > q3 + 3*iqr)).sum()
            out_pct = outliers / len(df) * 100
            rules.append({
                "rule": f"outliers_{col}",
                "passed": out_pct < max_outlier_pct,
                "detail": f"{outliers} outliers ({round(out_pct,3)}%)"
            })

        # Auto-fix
        original_len = len(df)
        df_clean = df.copy()
        for col in ["fare_amount", "trip_distance"]:
            q1, q99 = df_clean[col].quantile(0.01), df_clean[col].quantile(0.99)
            df_clean = df_clean[(df_clean[col] >= q1) & (df_clean[col] <= q99)]
        df_clean["passenger_count"] = df_clean["passenger_count"].fillna(df_clean["passenger_count"].median())
        df_clean = df_clean[df_clean["trip_distance"] > 0].reset_index(drop=True)

        _SHARED_STATE["df_clean"] = df_clean
        _SHARED_STATE["validation_rules"] = rules

        passed = sum(1 for r in rules if r["passed"])
        quality_score = round(passed / len(rules) * 100, 1)

        result = {
            "status": "success",
            "total_rules": len(rules),
            "passed": passed,
            "failed": len(rules) - passed,
            "quality_score": quality_score,
            "rows_original": original_len,
            "rows_after_fix": len(df_clean),
            "rows_removed": original_len - len(df_clean),
            "rules_detail": rules,
        }
        logger.info(f"[DataValidationTool] ✅ Score: {quality_score}% | {passed}/{len(rules)} regras")
        return json.dumps(result, indent=2, cls=NumpyEncoder)

    async def _arun(self, *args, **kwargs):
        raise NotImplementedError


