class DataTransformationTool(BaseTool):
    name: str = "data_transformation"
    description: str = (
        "Aplica feature engineering nos dados limpos. "
        "Cria features temporais, métricas de corrida, categorias e flags binárias. "
        "Retorna lista de features criadas e shape final do dataset."
    )
    args_schema: Type[BaseModel] = TransformInput

    def _run(self, include_temporal: bool = True, include_metrics: bool = True, include_flags: bool = True) -> str:
        df = _SHARED_STATE.get("df_clean")
        if df is None:
            return json.dumps({"error": "DataFrame limpo não encontrado. Execute data_validation primeiro."})

        logger.info(f"[DataTransformationTool] Transformando {len(df):,} registros")
        features_created = []

        if include_temporal:
            df["pickup_hour"] = df["tpep_pickup_datetime"].dt.hour
            df["pickup_day_name"] = df["tpep_pickup_datetime"].dt.day_name()
            df["pickup_month_name"] = df["tpep_pickup_datetime"].dt.month_name()
            df["is_weekend"] = df["tpep_pickup_datetime"].dt.dayofweek.isin([5,6]).astype(int)
            df["shift"] = pd.cut(df["pickup_hour"], bins=[-1,5,11,17,20,23],
                                  labels=["madrugada","manha","tarde","noite","noite_alta"])
            features_created += ["pickup_hour","pickup_day_name","pickup_month_name","is_weekend","shift"]

        if include_metrics:
            df["trip_duration_min"] = (
                (df["tpep_dropoff_datetime"] - df["tpep_pickup_datetime"])
                .dt.total_seconds() / 60
            ).round(2)
            df["trip_distance_km"] = (df["trip_distance"] * 1.60934).round(2)
            df["avg_speed_kmh"] = np.where(
                df["trip_duration_min"] > 0,
                (df["trip_distance_km"] / (df["trip_duration_min"] / 60)).round(2), 0
            )
            df["revenue_per_km"] = np.where(
                df["trip_distance_km"] > 0,
                (df["total_amount"] / df["trip_distance_km"]).round(2), 0
            )
            df["tip_rate_pct"] = np.where(
                df["fare_amount"] > 0,
                (df["tip_amount"] / df["fare_amount"] * 100).round(2), 0
            )
            df["distance_category"] = pd.cut(
                df["trip_distance_km"], bins=[0,2,5,10,20,float("inf")],
                labels=["muito_curta","curta","media","longa","muito_longa"]
            )
            df["payment_label"] = df["payment_type"].map({1:"cartao_credito",2:"dinheiro"}).fillna("outro")
            features_created += ["trip_duration_min","trip_distance_km","avg_speed_kmh",
                                   "revenue_per_km","tip_rate_pct","distance_category","payment_label"]

        if include_flags:
            df["has_tip"] = (df["tip_amount"] > 0).astype(int)
            df["has_toll"] = (df["tolls_amount"] > 0).astype(int)
            df["is_peak_hour"] = df["pickup_hour"].isin([7,8,9,17,18,19]).astype(int)
            df["is_late_night"] = df["pickup_hour"].isin([0,1,2,3,4]).astype(int)
            df["is_airport_trip"] = df["PULocationID"].isin([1,132,138]).astype(int)
            features_created += ["has_tip","has_toll","is_peak_hour","is_late_night","is_airport_trip"]

        _SHARED_STATE["df_transformed"] = df
        _SHARED_STATE["features_created"] = features_created

        result = {
            "status": "success",
            "features_created": len(features_created),
            "feature_names": features_created,
            "final_shape": {"rows": len(df), "columns": len(df.columns)},
            "total_columns": len(df.columns),
        }
        logger.info(f"[DataTransformationTool] ✅ {len(features_created)} features criadas")
        return json.dumps(result, indent=2, cls=NumpyEncoder)

    async def _arun(self, *args, **kwargs):
        raise NotImplementedError


