        _SHARED_STATE["report_path"] = report_path
        logger.info(f"[ReportGeneratorTool] ✅ Relatório salvo: {report_path}")

        return json.dumps({"status": "success", "report_path": report_path, "kpis_reported": len(kpis), "insights_reported": len(insights)}, indent=2)

