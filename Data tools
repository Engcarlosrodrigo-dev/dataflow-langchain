class DataAnalysisTool(BaseTool):
    name: str = "data_analysis"
    description: str = (
        "Realiza análise exploratória e gera insights automáticos sobre os dados transformados. "
        "Calcula KPIs, padrões temporais, análise de receita, gorjetas e detecção de anomalias."
    )
    args_schema: Type[BaseModel] = AnalyzeInput

    def _run(self, focus: str = "all") -> str:
        df = _SHARED_STATE.get("df_transformed")
        if df is None:
            return json.dumps({"error": "DataFrame transformado não encontrado. Execute data_transformation primeiro."})

        logger.info(f"[DataAnalysisTool] Analisando {len(df):,} registros | foco: {focus}")

        kpis = {
            "total_trips": int(len(df)),
            "total_revenue": round(float(df["total_amount"].sum()), 2),
            "avg_ticket": round(float(df["total_amount"].mean()), 2),
            "avg_distance_km": round(float(df["trip_distance_km"].mean()), 2),
            "avg_duration_min": round(float(df["trip_duration_min"].mean()), 2),
            "tip_rate_pct": round(float(df["has_tip"].mean() * 100), 2),
            "avg_tip": round(float(df.loc[df["has_tip"]==1, "tip_amount"].mean()), 2),
            "credit_card_pct": round(float((df["payment_type"]==1).mean() * 100), 2),
            "peak_hour_pct": round(float(df["is_peak_hour"].mean() * 100), 2),
            "airport_trip_pct": round(float(df["is_airport_trip"].mean() * 100), 2),
            "avg_speed_kmh": round(float(df["avg_speed_kmh"].median()), 2),
        }

        trips_by_hour = df.groupby("pickup_hour")["trip_id"].count().to_dict()
        trips_by_day = df.groupby("pickup_day_name")["trip_id"].count().to_dict()
        revenue_by_hour = df.groupby("pickup_hour")["total_amount"].sum().round(2).to_dict()

        peak_hour = int(max(trips_by_hour, key=trips_by_hour.get))
        busiest_day = max(trips_by_day, key=trips_by_day.get)
        best_revenue_hour = int(max(revenue_by_hour, key=revenue_by_hour.get))

        tips_by_hour = df[df["has_tip"]==1].groupby("pickup_hour")["tip_amount"].mean().round(2).to_dict()
        best_tip_hour = int(max(tips_by_hour, key=tips_by_hour.get))

        avg_peak = df.loc[df["is_peak_hour"]==1, "total_amount"].mean()
        avg_offpeak = df.loc[df["is_peak_hour"]==0, "total_amount"].mean()
        peak_premium = round((avg_peak / avg_offpeak - 1) * 100, 1)

        anomalies = []
        impossible = int((df["avg_speed_kmh"] > 150).sum())
        if impossible: anomalies.append(f"{impossible} corridas com velocidade > 150 km/h")
        zero_dur = int((df["trip_duration_min"] <= 0).sum())
        if zero_dur: anomalies.append(f"{zero_dur} corridas com duração <= 0 min")

        insights = [
            f"Horário de pico: {peak_hour}h com {trips_by_hour[peak_hour]:,} corridas",
            f"Melhor hora de receita: {best_revenue_hour}h — ${revenue_by_hour[best_revenue_hour]:,.2f}",
            f"Dia mais movimentado: {busiest_day}",
            f"Corridas no pico geram {peak_premium}% mais receita",
            f"Melhor horário para gorjetas: {best_tip_hour}h (média ${tips_by_hour[best_tip_hour]:.2f})",
            f"Taxa de gorjeta geral: {kpis['tip_rate_pct']}%",
            f"Cartão de crédito: {kpis['credit_card_pct']}% das corridas",
        ]

        result = {
            "status": "success",
            "kpis": kpis,
            "temporal": {"peak_hour": peak_hour, "busiest_day": busiest_day, "best_revenue_hour": best_revenue_hour},
            "insights": insights,
            "anomalies": anomalies,
            "insights_count": len(insights),
        }

        _SHARED_STATE["analysis"] = result
        logger.info(f"[DataAnalysisTool] ✅ {len(insights)} insights gerados | {len(anomalies)} anomalias")
        return json.dumps(result, indent=2, cls=NumpyEncoder)

    async def _arun(self, *args, **kwargs):
        raise NotImplementedError


