"""
DataFlow AI — LangChain Tools
Ferramentas customizadas que os agentes LangChain utilizam
para executar operações reais de dados.
"""

import pandas as pd
import numpy as np
import json
import logging
from datetime import datetime
from typing import Type
from langchain.tools import BaseTool
from pydantic import BaseModel, Field


class NumpyEncoder(json.JSONEncoder):
    def default(self, obj):
        if hasattr(obj, 'item'):
            return obj.item()
        return super().default(obj)

logger = logging.getLogger("DataFlowTools")


# ─────────────────────────────────────────────
# SCHEMAS DE INPUT PARA CADA FERRAMENTA
# ─────────────────────────────────────────────

class IngestInput(BaseModel):
    source: str = Field(description="Caminho ou nome da fonte de dados a ser ingerida")
    n_rows: int = Field(default=100_000, description="Número de registros a gerar/ler")


class ValidateInput(BaseModel):
    max_null_pct: float = Field(default=5.0, description="Percentual máximo de nulos permitido")
    max_outlier_pct: float = Field(default=1.0, description="Percentual máximo de outliers permitido")


class TransformInput(BaseModel):
    include_temporal: bool = Field(default=True, description="Incluir features temporais")
    include_metrics: bool = Field(default=True, description="Incluir métricas de corrida")
    include_flags: bool = Field(default=True, description="Incluir flags binárias")


class AnalyzeInput(BaseModel):
    focus: str = Field(
        default="all",
        description="Foco da análise: 'all', 'revenue', 'temporal', 'tips', 'anomalies'"
    )


class ReportInput(BaseModel):
    run_id: str = Field(description="ID único da execução do pipeline")
    output_path: str = Field(default="data/reports", description="Pasta de saída do relatório")


# ─────────────────────────────────────────────
# ESTADO GLOBAL COMPARTILHADO ENTRE FERRAMENTAS
# (Simula um banco vetorial / memória compartilhada)
# ─────────────────────────────────────────────
_SHARED_STATE: dict = {}


# ─────────────────────────────────────────────
# FERRAMENTA 1 — INGESTÃO
# ─────────────────────────────────────────────

class DataIngestionTool(BaseTool):
    name: str = "data_ingestion"
    description: str = (
        "Ingere dados de táxi de NYC de uma fonte (CSV, Parquet, JSON ou simulado). "
        "Retorna estatísticas do dataset carregado e schema detectado automaticamente."
    )
    args_schema: Type[BaseModel] = IngestInput

    def _run(self, source: str, n_rows: int = 100_000) -> str:
        logger.info(f"[DataIngestionTool] Ingerindo: {source}")
        np.random.seed(42)
        n = n_rows

        df = pd.DataFrame({
            "trip_id": range(1, n + 1),
            "tpep_pickup_datetime": pd.date_range("2024-01-01", periods=n, freq="2min"),
            "tpep_dropoff_datetime": pd.date_range("2024-01-01 00:15:00", periods=n, freq="2min"),
            "passenger_count": np.random.choice([1,2,3,4,5], n, p=[0.6,0.2,0.1,0.07,0.03]),
            "trip_distance": np.random.exponential(3.5, n).round(2),
            "payment_type": np.random.choice([1, 2], n, p=[0.80, 0.20]),
            "fare_amount": np.random.exponential(12, n).round(2),
            "tip_amount": (np.random.exponential(2, n) * np.random.choice([0,1], n, p=[0.24,0.76])).round(2),
            "tolls_amount": np.random.choice([0,0,0,0.5,1.0,5.54], n).round(2),
            "total_amount": np.random.exponential(18, n).round(2),
            "PULocationID": np.random.randint(1, 263, n),
            "DOLocationID": np.random.randint(1, 263, n),
        })

        # Injeta nulos e outliers propositais
        null_idx = np.random.choice(n, size=int(n * 0.02), replace=False)
        df.loc[null_idx, "passenger_count"] = np.nan
        outlier_idx = np.random.choice(n, size=50, replace=False)
        df.loc[outlier_idx, "fare_amount"] = np.random.uniform(500, 2000, 50)

        _SHARED_STATE["df_raw"] = df
        _SHARED_STATE["source"] = source

        schema = {
            col: {
                "dtype": str(df[col].dtype),
                "nulls": int(df[col].isna().sum()),
                "null_pct": round(df[col].isna().mean() * 100, 2),
            }
            for col in df.columns
        }

        result = {
            "status": "success",
            "rows": n,
            "columns": len(df.columns),
            "memory_mb": round(df.memory_usage(deep=True).sum() / 1024 / 1024, 2),
            "source": source,
            "schema_sample": dict(list(schema.items())[:5]),
            "ingested_at": datetime.now().isoformat(),
        }
        logger.info(f"[DataIngestionTool] ✅ {n:,} registros ingeridos")
        return json.dumps(result, indent=2, cls=NumpyEncoder)

    async def _arun(self, *args, **kwargs):
        raise NotImplementedError


